# Server port
PORT=3000

# JWT secret — change this to any long random string
JWT_SECRET=gridguard_secret_key_change_this_before_demo

# MySQL / XAMPP settings
# XAMPP MySQL runs on port 3306 by default.
# Default XAMPP root user has no password — leave DB_PASSWORD blank.
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=gridguard
